# Controla o que o `gcloud builds submit` ENVIA ao Cloud Build. Segredos e
# artefatos pesados nunca sobem.
.git/
.gitignore
.github/

# Segredos — NUNCA enviar
secrets/
.env
.env.production
*service-account*.json
*service_account*.json
client_secret*.json
*oauth*token*.json
token.json
credentials*.json

# Frontend (buildado à parte: Vercel / Dockerfile.web)
certificados-admin/frontend/node_modules/
certificados-admin/frontend/dist/

# Caches / venv
**/__pycache__/
**/*.pyc
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Dados/artefatos (PII / runtime)
data/
storage/pdfs/
*.db
*.db-wal
*.db-shm
*.pdf
*.xlsx
*.log
