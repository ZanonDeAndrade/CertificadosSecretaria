# Copie para .env.production em CADA servidor. Não coloque segredos neste arquivo.
COMPOSE_PROJECT_NAME=certificados
PRODUCTION_ENV_FILE=.env.production
APP_IMAGE=certificados-app:latest
WEB_IMAGE=certificados-web:latest

# Domínios. Ambos precisam resolver para o IP deste servidor para TLS público.
PUBLIC_DOMAIN=certificados.exemplo.edu.br
ADMIN_DOMAIN=admin-certificados.exemplo.edu.br
TLS_EMAIL=infra@exemplo.edu.br
PUBLIC_VALIDATION_BASE_URL=https://certificados.exemplo.edu.br
ADMIN_FRONTEND_URL=https://admin-certificados.exemplo.edu.br
CORS_ALLOWED_ORIGINS=https://admin-certificados.exemplo.edu.br

# Para LAN sem domínio público, use ./deploy/Caddyfile.internal e DNS interno.
CADDY_CONFIG_FILE=./deploy/Caddyfile

# Caminhos NO HOST. O Compose os monta em /run/secrets nos containers.
DATABASE_URL_SECRET_FILE=/opt/certificados/secrets/database_url
GOOGLE_OAUTH_TOKEN_SECRET_FILE=/opt/certificados/secrets/google_oauth_token.json
JWT_SECRET_FILE_HOST=/opt/certificados/secrets/jwt_secret
DOCUMENT_HASH_SECRET_FILE_HOST=/opt/certificados/secrets/document_hash_secret
BACKUP_DIR=/opt/certificados/backups

# Aplicação
APP_ENV=production
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
JWT_EXPIRES_IN_MINUTES=480
MINIMIZE_DOCUMENT_PLAINTEXT=true
PRIVATE_DATA_RETENTION_DAYS=0
TRUSTED_PROXY_CIDRS=172.16.0.0/12

# Neon pooled connection: poucos sockets por processo são suficientes.
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=300

# Google Drive pessoal via OAuth
STORAGE_PROVIDER=google_drive
GOOGLE_DRIVE_AUTH_MODE=oauth_user
GOOGLE_DRIVE_CERTIFICATES_FOLDER_ID=1aXRVubgM5LC0OStdRr8HJUBjqRtiiizB

# Capacidade inicial
ADMIN_WORKERS=1
CONSULTA_WORKERS=1
MAX_CERTIFICATE_FILE_SIZE_MB=15
MAX_SPREADSHEET_FILE_SIZE_MB=10

# Rate limits
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_MAX_FAILURES_PER_IP=20
LOGIN_MAX_FAILURES_PER_USER=8
LOGIN_LOCKOUT_SECONDS=900
PUBLIC_RATE_LIMIT_REQUESTS=60
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
