# ==============================================================================
# Exemplo da stack de desenvolvimento docker-compose.yml.
# PRODUÇÃO: use .env.production.example + compose.production.yaml.
# Copie para ".env" (mesma pasta do docker-compose.yml) e preencha.
# NUNCA comite o .env nem o JSON da Service Account.
# ==============================================================================

# ---- Banco de dados (PostgreSQL no container 'db') ---------------------------
POSTGRES_USER=certuser
POSTGRES_PASSWORD=TROQUE_por_uma_senha_forte
POSTGRES_DB=certificados
DATABASE_URL=postgresql://certuser:TROQUE_por_uma_senha_forte@db:5432/certificados
# Alternativa para banco externo/secret file: DATABASE_URL_FILE=/run/secrets/database_url

# ---- Ambiente ----------------------------------------------------------------
# FASE DE TESTE (sem domínio, HTTP): use development + cookie não-secure abaixo.
# DEPOIS (com domínio + HTTPS): troque para APP_ENV=production e REMOVA a linha
# AUTH_COOKIE_SECURE (o cookie passa a Secure automaticamente).
APP_ENV=development
AUTH_COOKIE_SECURE=false

# ---- Segredos (gere aleatórios; mínimo 32 bytes; valores DIFERENTES) ---------
#   Linux:  openssl rand -base64 48
JWT_SECRET=GERAR_32+_bytes_aleatorios
DOCUMENT_HASH_SECRET=GERAR_OUTRO_32+_bytes_aleatorios

# ---- Usuário administrativo inicial (criado no 1º start) ---------------------
ADMIN_INITIAL_USERNAME=secretaria
ADMIN_INITIAL_PASSWORD=TROQUE_por_uma_senha_forte
ADMIN_INITIAL_ROLE=admin

# ---- URLs / CORS / proxy -----------------------------------------------------
# TESTE: use o IP (ou hostname) do servidor. ADMIN na porta 8080, consulta na 80.
ADMIN_FRONTEND_URL=http://SEU_IP_DO_SERVIDOR:8080
PUBLIC_VALIDATION_BASE_URL=http://SEU_IP_DO_SERVIDOR
# Confiar no X-Forwarded-For vindo do nginx (rede interna do compose).
TRUSTED_PROXY_CIDRS=172.16.0.0/12

# ---- Armazenamento: GOOGLE DRIVE ---------------------------------------------
STORAGE_PROVIDER=google_drive
GOOGLE_DRIVE_AUTH_MODE=service_account
# ID da pasta (ou Shared Drive) compartilhada com a Service Account.
GOOGLE_DRIVE_CERTIFICATES_FOLDER_ID=COLE_O_ID_DA_PASTA
# Conteúdo do JSON da Service Account em base64 (NUNCA o JSON cru):
#   Linux:  base64 -w0 service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=COLE_O_BASE64_DO_JSON
# Alternativa para Meu Drive pessoal:
# GOOGLE_DRIVE_AUTH_MODE=oauth_user
# GOOGLE_OAUTH_TOKEN_JSON_BASE64=COLE_O_BASE64_DO_TOKEN_OAUTH

# ---- Frontend (build) --------------------------------------------------------
# "/api" = mesma origem do SPA admin (porta 8080) → sem problema de CORS/cookie.
VITE_API_BASE_URL=/api

# ---- Workers (2 núcleos / 2-4 GB) --------------------------------------------
# Comece com 1 cada. Com 4 GB pode subir admin para 2.
ADMIN_WORKERS=1
CONSULTA_WORKERS=1
