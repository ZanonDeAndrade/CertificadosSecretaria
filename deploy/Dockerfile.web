# Build do frontend React (Vite) + nginx servindo o estático e fazendo proxy.
FROM node:20-alpine AS build
WORKDIR /fe
COPY certificados-admin/frontend/package*.json ./
RUN npm ci
COPY certificados-admin/frontend/ ./
# Base da API embutida no build. "/api" = mesma origem do SPA admin (porta 8080).
ARG VITE_API_BASE_URL=/api
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /fe/dist /usr/share/nginx/html
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80 8080
