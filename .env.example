# Configuração COMPARTILHADA pelos dois projetos (certificados-admin e
# certificados-consulta). Copie para ".env" na RAIZ e preencha.
# NÃO coloque valores reais aqui nem versione o .env.

# Ambiente: "development" ou "production".
# Em production:
#   - o cookie de sessão é marcado como Secure por padrão;
#   - a aplicação FALHA AO INICIAR se faltar DATABASE_URL (PostgreSQL),
#     JWT_SECRET forte, ADMIN_FRONTEND_URL/CORS_ALLOWED_ORIGINS,
#     PUBLIC_VALIDATION_BASE_URL, a pasta do Drive ou as credenciais do Drive;
#   - STORAGE_PROVIDER precisa ser "google_drive" (sem fallback local).
APP_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# URLs / CORS
# ─────────────────────────────────────────────────────────────────────────────
# Origem do frontend administrativo (React) — allowlist CORS e Origin/Referer.
# Obrigatória e HTTPS em produção. Não inclua a aplicação pública nesta lista.
ADMIN_FRONTEND_URL=http://localhost:5173
# URL base pública para o QR Code de validação. Barras finais são normalizadas.
# O QR aponta sempre para: PUBLIC_VALIDATION_BASE_URL/validar/<codigo>
# Em produção é obrigatória, deve ser HTTPS e não pode ter credenciais, query ou fragmento.
PUBLIC_VALIDATION_BASE_URL=http://localhost:8001
# Apenas proxies reversos controlados podem fornecer X-Forwarded-For.
# Use redes CIDR específicas; redes irrestritas /0 são rejeitadas.
TRUSTED_PROXY_CIDRS=
# Alternativa/override: lista de origens administrativas separadas por vírgula.
# CORS_ALLOWED_ORIGINS=https://admin.exemplo.edu.br

# ─────────────────────────────────────────────────────────────────────────────
# Banco de dados (compartilhado pelos dois projetos)
# ─────────────────────────────────────────────────────────────────────────────
# PRODUÇÃO: PostgreSQL via DATABASE_URL (OBRIGATÓRIO). Aceita postgres:// ,
# postgresql:// ou postgresql+psycopg:// (normalizado para psycopg 3).
#   DATABASE_URL=postgresql://usuario:senha@host:5432/certificados
# O schema é gerenciado por migrations Alembic:  alembic upgrade head
DATABASE_URL=
# Alternativa segura: arquivo contendo somente a connection string.
DATABASE_URL_FILE=
# DESENVOLVIMENTO/TESTE (apenas quando DATABASE_URL está vazio): SQLite local.
# Caminho do arquivo .db. Sem valor → usa <repo>/database/certificates.db.
DB_PATH=
# Pool de conexões (PostgreSQL). Valores padrão entre parênteses.
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800

# ─────────────────────────────────────────────────────────────────────────────
# Armazenamento dos PDFs
# ─────────────────────────────────────────────────────────────────────────────
# "local" (desenvolvimento) ou "google_drive" (produção, OBRIGATÓRIO).
# Em produção o Drive é o único armazenamento definitivo: não há fallback local.
# Vazio → "local" em dev e "google_drive" em produção.
STORAGE_PROVIDER=local
# Raiz do storage local (PDFs em <LOCAL_STORAGE_PATH>/pdfs). Vazio → <repo>/storage.
# Usado APENAS em desenvolvimento; ignorado em produção.
LOCAL_STORAGE_PATH=

# ── Google Drive (quando STORAGE_PROVIDER=google_drive) ───────────────────────
# "service_account" (Drive compartilhado) ou "oauth_user" (Meu Drive pessoal).
GOOGLE_DRIVE_AUTH_MODE=service_account
# ID da pasta do Drive (compartilhe-a com o e-mail da Service Account).
GOOGLE_DRIVE_CERTIFICATES_FOLDER_ID=
# Credenciais da Service Account — use UMA das opções. NUNCA comite o JSON.
# (Produção) JSON inteiro em base64:
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
#   Linux/macOS: base64 -w0 service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
# (Dev local) caminho para o arquivo JSON da Service Account:
GOOGLE_SERVICE_ACCOUNT_FILE=
# OAuth de usuário: token offline criado por authorize_google_drive.py.
# Produção/container: prefira o JSON completo do token em base64.
GOOGLE_OAUTH_TOKEN_JSON_BASE64=
# Desenvolvimento local: caminho absoluto do token OAuth.
GOOGLE_OAUTH_TOKEN_FILE=

# ─────────────────────────────────────────────────────────────────────────────
# Autenticação da secretaria
# ─────────────────────────────────────────────────────────────────────────────
# Segredo para assinar o JWT (OBRIGATÓRIO em produção).
# Gere pelo menos 32 bytes criptograficamente aleatórios; valores repetitivos
# ou com baixa entropia aparente são rejeitados no startup.
#   Linux/macOS: openssl rand -base64 32
#   PowerShell: $b = [byte[]]::new(32); [Security.Cryptography.RandomNumberGenerator]::Fill($b)
#               [Convert]::ToBase64String($b)
JWT_SECRET=
JWT_SECRET_FILE=
# HMAC de documento e desafios opacos da busca pública. Obrigatório e com pelo
# menos 32 bytes aleatórios em produção; use valor diferente de JWT_SECRET.
DOCUMENT_HASH_SECRET=
DOCUMENT_HASH_SECRET_FILE=
# Validade do token de sessão, em minutos (padrão: 480 = 8h).
JWT_EXPIRES_IN_MINUTES=480
# Cookie: HttpOnly é sempre habilitado. Secure é obrigatório em produção.
AUTH_COOKIE_SECURE=false
# lax (padrão), strict ou none. "none" exige Secure=true.
AUTH_COOKIE_SAMESITE=lax
# Sessões expiradas são removidas após esta retenção (dias).
AUTH_SESSION_RETENTION_DAYS=30
# Usuário admin inicial — criado no 1º start se não existir
# (alternativa: python create_admin.py <usuario> <senha>).
ADMIN_INITIAL_USERNAME=
ADMIN_INITIAL_PASSWORD=
# admin | secretaria | auditor
ADMIN_INITIAL_ROLE=admin

# Proteção persistente/distribuída do login (estado no PostgreSQL compartilhado).
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_MAX_FAILURES_PER_USER=8
LOGIN_MAX_FAILURES_PER_IP=20
LOGIN_LOCKOUT_SECONDS=900
LOGIN_BACKOFF_BASE_MS=250
LOGIN_BACKOFF_MAX_MS=4000

# ─────────────────────────────────────────────────────────────────────────────
# Consulta pública, minimização e retenção
# ─────────────────────────────────────────────────────────────────────────────
PUBLIC_NAME_SEARCH_MIN_LENGTH=3
PUBLIC_MAX_PAGE=100
PUBLIC_RATE_LIMIT_REQUESTS=60
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_DOCUMENT_ATTEMPTS_PER_WINDOW=5
# true: nunca persiste documento/CPF/matrícula em claro; guarda somente HMAC.
MINIMIZE_DOCUMENT_PLAINTEXT=true
# 0 desabilita expurgo automático. Se >0, e-mail e eventual documento legado
# em claro são apagados quando o certificado ultrapassa a idade configurada.
PRIVATE_DATA_RETENTION_DAYS=0

# ─────────────────────────────────────────────────────────────────────────────
# Limites da planilha
# ─────────────────────────────────────────────────────────────────────────────
MAX_SPREADSHEET_SIZE_MB=10
MAX_SPREADSHEET_ROWS=2000

# ─────────────────────────────────────────────────────────────────────────────
# Dados institucionais impressos no certificado (sem hardcode no código)
# ─────────────────────────────────────────────────────────────────────────────
ISSUE_LOCATION=
SIGNATORY_NAME=
SIGNATORY_TITLE=
